{
  "type": "lithostitched:add_surface_rule",
  "levels": [
    "minecraft:overworld"
  ],
  "surface_rule": {
    "type": "minecraft:condition",
    "if_true": {
      "type": "minecraft:biome",
      "biome_is": ["modpack:clayland"]
    },
    "then_run": {
      "type": "minecraft:condition",
      "if_true": {
        "type": "minecraft:noise_threshold",
        "noise": "minecraft:surface",
        "min_threshold": -64,
        "max_threshold": 256
      },
      "then_run": {
        "type": "minecraft:block",
        "result_state": {
            "Name": "minecraft:clay"
        }
      }
    }
  }
}